{
  "name": "@indev42/zwidget",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "A vite plugin for creating Zoho widget artifacts.",
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/indev42/zwidget.git"
  },
  "bugs": {
    "url": "https://github.com/indev42/zwidget/issues"
  },
  "homepage": "https://github.com/indev42/zwidget#readme",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "dev": "tsdown --watch",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "bun run build",
    "version-packages": "changeset version"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
